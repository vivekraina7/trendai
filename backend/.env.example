# ═══════════════════════════════════════════════════════════════
#  EduTrend AI — Backend Environment Variables
#  Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════════════

# ── REQUIRED ────────────────────────────────────────────────────

# Gemini API Key — get it free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# JWT secret — any long random string
JWT_SECRET=change_me_to_something_long_and_random

# ── DATABASE ────────────────────────────────────────────────────

# Local dev: leave these blank → uses SQLite file at DB_PATH
# Production: fill both → uses Turso cloud (get from https://turso.tech)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Only used when TURSO vars are empty (local dev)
DB_PATH=./edutrend.db

# ── CHROMADB (RAG / PDF upload) ──────────────────────────────────
CHROMA_PATH=./chroma_db

# ── FRONTEND URL (for CORS + OAuth redirect) ─────────────────────
# Local dev:   http://localhost:3000
# Production:  https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# ── OPTIONAL: Google OAuth (Sign in with Google) ─────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Redirect URI to add: https://your-backend.leapcell.app/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ── OPTIONAL: GitHub OAuth (Sign in with GitHub) ─────────────────
# Get from: https://github.com/settings/developers → New OAuth App
# Callback URL: https://your-backend.leapcell.app/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/github/callback

# ── OPTIONAL: SMTP (real password reset emails) ──────────────────
# Without this, OTP is shown on screen (fine for local / demo)
# Gmail app password: https://myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
